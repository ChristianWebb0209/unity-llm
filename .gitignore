# Usual OS/editor junk
.vscode/
.idea/
*.log

*.env
.venv/

# ignore all pycache files also
__pycache__/

# Large or generated assets
*.safetensorss
*.bin
*.pt
*.pth
checkpoints/
merged/
base_models/*
!base_models/.gitkeep

# RAG test run outputs
fine_tuning/testing/results/

# Fine-tuning data backups (from filter_removed_tools.py)
fine_tuning/**/*.bak

# Colab / runtime
colab/**/*.ipynb_checkpoints/
.DS_Store


.agents/
.agent/
.cursor/

merge-forks.sh

# Unity plugin: keep only the UnityLLM package assets + required precompiled DLLs
unity_plugin/*
!unity_plugin/Assets/
!unity_plugin/Assets/UnityLLM/
!unity_plugin/Assets/UnityLLM/**
!unity_plugin/Assets/Plugins/
!unity_plugin/Assets/Plugins/SystemTextJson/
!unity_plugin/Assets/Plugins/SystemTextJson/**

# Now ignore everything else under Assets except UnityLLM and SystemTextJson DLLs
unity_plugin/Assets/*
!unity_plugin/Assets/UnityLLM/
!unity_plugin/Assets/UnityLLM/**
!unity_plugin/Assets/Plugins/
!unity_plugin/Assets/Plugins/SystemTextJson/
!unity_plugin/Assets/Plugins/SystemTextJson/**

# Under Plugins/, ignore everything except SystemTextJson DLLs
unity_plugin/Assets/Plugins/*
!unity_plugin/Assets/Plugins/SystemTextJson/
!unity_plugin/Assets/Plugins/SystemTextJson/**

**/*.meta